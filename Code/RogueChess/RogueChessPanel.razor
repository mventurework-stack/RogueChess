@using Sandbox
@using Sandbox.UI
@using System
@namespace StrategyGame
@inherits Panel

<root class="scrap-chess">
	<div class="arena-background"></div>
	<div class="arena-overlay"></div>
	<div class="game-ui">
	@if ( Game is null )
	{
		<div class="missing">Attach RogueChessGameComponent or assign Game on this panel.</div>
	}
	else
	{
		@if ( ShowArmyBuilder )
		{
			<div class="army-builder-screen">
				<div class="builder-left">
					<div class="builder-logo-mark"></div>
					<div class="builder-logo">
						<div>ROGUE</div>
						<div>CHESS</div>
					</div>
					<div class="builder-subtitle">Build Your Army</div>
					<div class="builder-copy">Choose 7 units to join your Commander into battle.</div>
					@if ( !string.IsNullOrEmpty( BuilderNotice ) )
					{
						<div class="builder-notice">@BuilderNotice</div>
					}
					<div class="@StartMatchButtonClass" onclick=@TryStartMatch>Start Game</div>
					<div class="builder-menu-button" onclick=@ShowSettingsStatus>Settings</div>
					<div class="difficulty-panel">
						<div class="difficulty-title">Difficulty</div>
						<div class="difficulty-buttons">
							<div class="@GetDifficultyButtonClass( AiDifficulty.Beginner )" onclick=@( () => Game.SetDifficulty( AiDifficulty.Beginner ) )>Beginner</div>
							<div class="@GetDifficultyButtonClass( AiDifficulty.Intermediate )" onclick=@( () => Game.SetDifficulty( AiDifficulty.Intermediate ) )>Intermediate</div>
							<div class="@GetDifficultyButtonClass( AiDifficulty.Hard )" onclick=@( () => Game.SetDifficulty( AiDifficulty.Hard ) )>Hard</div>
						</div>
					</div>
					<div class="builder-menu-button builder-bottom-button" onclick=@ShowHowToPlay>How To Play</div>
				</div>

				<div class="builder-center">
					<div class="builder-panel">
						<div class="builder-header">
							<div class="builder-title">Your Army</div>
							<div class="builder-count">@Game.BlueArmyFilledSlots/8</div>
						</div>
						<div class="army-builder-slots">
							@for ( var slot = 0; slot < Game.BlueArmyChoices.Count; slot++ )
							{
								var armySlot = slot;
								var slotType = Game.BlueArmyChoices[armySlot];
								var isCommanderSlot = armySlot == RogueChessGameComponent.CommanderArmySlotIndex;
								if ( slotType.HasValue )
								{
									var unitType = slotType.Value;
									<div class="@GetBuilderSlotClass( unitType, true, isCommanderSlot )" onclick=@( () => ClickArmyBuilderSlot( armySlot ) )>
										<div class="slot-number">@(armySlot + 1)</div>
										<div class="slot-unit-name">@unitType</div>
										<div class="@GetBuilderPortraitClass( unitType )">
											<div class="piece-art">
												<div class="piece-label">@GetUnitShortName( unitType )</div>
											</div>
										</div>
										<div class="slot-lock">@GetBuilderSlotActionText( armySlot, unitType )</div>
									</div>
								}
								else
								{
									<div class="builder-slot empty" onclick=@( () => Game.SetBlueArmySlot( armySlot ) )>
										<div class="slot-number">@(armySlot + 1)</div>
										<div class="slot-plus">+</div>
										<div class="slot-empty-text">Empty Slot</div>
									</div>
								}
							}
						</div>

						<div class="unit-pool-header">
							<div class="unit-pool-title">Unit Pool</div>
							<div class="unit-pool-copy">Select a unit card, then click an army slot.</div>
						</div>
						<div class="unit-pool">
							@foreach ( var unitType in Game.UnitPoolTypes )
							{
								var preview = Game.CreatePreviewUnit( unitType );
								<div class="@GetBuilderUnitCardClass( unitType )" onclick=@( () => SelectBuilderUnit( unitType ) )>
									<div class="unit-card-type">@unitType</div>
									<div class="@GetBuilderPortraitClass( unitType )">
										<div class="piece-art">
											<div class="piece-label">@preview.ShortName</div>
										</div>
									</div>
									<div class="unit-card-role">@Game.GetUnitRole( unitType )</div>
									<div class="unit-card-stats">HP @preview.MaxHealth / MV @preview.MoveRange / RNG @preview.AttackRange / DMG @preview.Damage</div>
								</div>
							}
						</div>
					</div>
				</div>

				<div class="builder-right">
					<div class="details-card">
						@{
							var details = Game.CreatePreviewUnit( BuilderDetailsUnit );
						}
						<div class="details-kicker">Selected Unit</div>
						<div class="details-title">@BuilderDetailsUnit</div>
						<div class="details-role">@Game.GetUnitRole( BuilderDetailsUnit )</div>
						<div class="@GetBuilderPortraitClass( BuilderDetailsUnit )">
							<div class="piece-art">
								<div class="piece-label">@details.ShortName</div>
							</div>
						</div>
						<div class="details-stats">
							<div>Health <span>@details.MaxHealth</span></div>
							<div>Movement <span>@details.MoveRange</span></div>
							<div>Attack Range <span>@details.AttackRange</span></div>
							<div>Damage <span>@details.Damage</span></div>
						</div>
						<div class="details-note">@Game.GetUnitDescription( BuilderDetailsUnit )</div>
					</div>
					<div class="details-card compact">
						<div class="details-kicker">Army Rules</div>
						<div class="builder-rule">Commander is locked.</div>
						<div class="builder-rule">Choose exactly 7 additional units.</div>
						<div class="builder-rule">Any combination of Buddy, Shooter, Tank, and Hacker is legal.</div>
						<div class="builder-rule">Start Game unlocks at 8/8.</div>
					</div>
				</div>
			</div>
		}
		else if ( ShowIntro )
		{
			<div class="intro-screen">
				<div class="intro-title">Rogue Chess V2</div>
				<div class="intro-page-label">Page @(IntroPage + 1) of @IntroPageCount</div>

				@if ( IntroPage == 0 )
				{
					<div class="intro-panel">
						<div class="intro-card-title">1. What you are trying to do</div>
						<div class="intro-card-text">Blue starts at the bottom. Red starts at the top.</div>
						<div class="intro-card-text">Each side has one Commander. Your goal is to attack the enemy Commander until its health reaches 0.</div>
						<div class="intro-card-text">Protect your own Commander. If your Commander reaches 0 health, you lose.</div>
					</div>
				}
				else if ( IntroPage == 1 )
				{
					<div class="intro-panel">
						<div class="intro-card-title">2. What to do on your turn</div>
						<div class="intro-step">Click one of your units.</div>
						<div class="intro-step">Then click a highlighted tile to move, or a highlighted enemy to attack.</div>
						<div class="intro-step">You may also play one card from your hand before or after the unit action.</div>
						<div class="intro-step">When you are done, click End Turn (or press Space or Tab).</div>
						<div class="intro-step">The mode button can switch between Player vs Computer and Computer vs Computer.</div>
					</div>
				}
				else if ( IntroPage == 2 )
				{
					<div class="intro-panel">
						<div class="intro-card-title">3. The most important rule</div>
						<div class="intro-card-text">A unit can move OR attack on its turn. It cannot do both.</div>
						<div class="intro-card-text">That means positioning matters. Sometimes moving to a better square is stronger than attacking right away.</div>
						<div class="intro-card-text">Units move up, down, left, and right. They do not move diagonally.</div>
					</div>
				}
				else if ( IntroPage == 3 )
				{
					<div class="intro-panel unit-page">
						<div class="intro-card-title">4. Your units</div>
						<div class="instruction-unit-list">
							<div class="instruction-unit-row">
								<div class="instruction-unit-image commander-blue"></div>
								<div class="instruction-unit-copy">
									<div class="instruction-unit-name">Commander</div>
									<div class="instruction-unit-text">Your most important unit. If it is defeated, you lose.</div>
								</div>
							</div>
							<div class="instruction-unit-row">
								<div class="instruction-unit-image buddy-blue"></div>
								<div class="instruction-unit-copy">
									<div class="instruction-unit-name">Buddy</div>
									<div class="instruction-unit-text">A fast scout. Good for collecting Scrap, flanking, blocking, and pressuring Shooters.</div>
								</div>
							</div>
							<div class="instruction-unit-row">
								<div class="instruction-unit-image shooter-blue"></div>
								<div class="instruction-unit-copy">
									<div class="instruction-unit-name">Shooter</div>
									<div class="instruction-unit-text">A fragile ranged unit. Good for attacking from a distance, but easy to lose.</div>
								</div>
							</div>
							<div class="instruction-unit-row">
								<div class="instruction-unit-image tank-blue"></div>
								<div class="instruction-unit-copy">
									<div class="instruction-unit-name">Tank</div>
									<div class="instruction-unit-text">A durable frontline unit. Good for holding territory and protecting allies.</div>
								</div>
							</div>
							<div class="instruction-unit-row">
								<div class="instruction-unit-image hacker-blue"></div>
								<div class="instruction-unit-copy">
									<div class="instruction-unit-name">Hacker</div>
									<div class="instruction-unit-text">A fragile control unit. It may disable an adjacent enemy instead of attacking.</div>
								</div>
							</div>
						</div>
					</div>
				}
				else if ( IntroPage == 4 )
				{
					<div class="intro-panel">
						<div class="intro-card-title">5. What the colors mean</div>
						<div class="intro-legend move">Green outline: this is a legal move tile.</div>
						<div class="intro-legend attack">Red outline: this enemy can be attacked.</div>
						<div class="intro-legend card-target">Yellow outline: your selected card can target this tile.</div>
						<div class="intro-legend selected">White outline: this is your selected unit.</div>
					</div>
				}
				else if ( IntroPage == 5 )
				{
					<div class="intro-panel first-move">
						<div class="intro-card-title">6. Scrap tiles and cards</div>
						<div class="intro-card-text">Scrap is the resource used to play cards.</div>
						<div class="intro-card-text">At the start of every turn, you gain 1 Scrap automatically.</div>
						<div class="intro-card-text">The board has center squares labeled Scrap Tile. If one of your units is standing on a Scrap Tile when your turn starts, you gain +1 extra Scrap for that unit.</div>
						<div class="intro-card-text">Buddy moves up to 2 tiles, while Commander and Shooter move 1. That is why Buddy is best at reaching Scrap Tiles early.</div>
						<div class="intro-card-text">Cards are automatic. At the start of your turn, the game adds 1 card to your hand.</div>
						<div class="intro-card-text">Your hand can hold 5 cards. If your hand is full, you do not draw another card.</div>
					</div>
				}
				else
				{
					<div class="intro-panel first-move">
						<div class="intro-card-title">7. Playing cards</div>
						<div class="intro-card-text">You may play only 1 card each turn. Cards are optional and do not replace your unit action.</div>
						<div class="intro-card-text">Click the selected card again or use Cancel Card if you change your mind.</div>
						<div class="intro-card-text">Build Buddy creates a Buddy beside your Commander, but that Buddy acts next turn.</div>
						<div class="intro-card-text">Try this first: click Blue Buddy or Blue Shooter, move toward a center Scrap tile, then click End Turn.</div>
					</div>
				}

				<div class="intro-footer">
					<div class="intro-note">Tip: this plays more like chess than a dice game. You lose from bad position, not bad luck.</div>
					<div class="intro-nav">
						<div class="@IntroBackClass" onclick=@PreviousIntroPage>Back</div>
						@if ( IntroPage < IntroPageCount - 1 )
						{
							<div class="skip-button" onclick=@StartGame>Skip</div>
						}
						@if ( IntroPage < IntroPageCount - 1 )
						{
							<div class="start-button" onclick=@NextIntroPage>Next</div>
						}
						else
						{
							<div class="start-button" onclick=@StartGame>Start Match</div>
						}
					</div>
				</div>
			</div>
		}
		else
		{
			@if ( Game.Winner is not null )
			{
				<div class="winner-overlay">
					<div class="winner-banner @(Game.Winner.Value == RogueChessTeam.Blue ? "winner-blue" : "winner-red")">@Game.TeamName( Game.Winner.Value ) Wins!</div>
					<div class="winner-reason">@WinnerReasonText</div>
				</div>
			}
			<div class="topbar">
				<div class="brand">Rogue Chess V2</div>
				<div class="turn @Game.CurrentTeam.ToString().ToLower()">@Game.TeamName( Game.CurrentTeam ) Turn</div>
				<div class="mode">@ModeText</div>
				<div class="instructions-button" onclick=@ShowHowToPlay>Instructions</div>
			</div>

			<div class="play-area">
				<div class="hand-panel blue-hand @(Game.CurrentTeam == RogueChessTeam.Blue ? "active-hand" : "inactive-hand")">
					<div class="hand-info">
						<div class="hand-title">Blue Player</div>
						<div class="side-scrap">Scrap: @Game.BlueScrap</div>
						<div class="hand-help">Draws 1 card at start of Blue turn.</div>
					</div>
					@for ( var i = 0; i < Game.BlueHand.Count; i++ )
					{
						var card = Game.BlueHand[i];
						var index = i;
						var visual = CardData.Visuals[card];
						var cardImageClass = GetCardImageClass( card, RogueChessTeam.Blue );
						var expanded = Game.CurrentTeam == RogueChessTeam.Blue && Game.SelectedCardIndex == index;
						<div class="@(Game.GetCardClass( RogueChessTeam.Blue, index ) + " " + visual.ArtClass)" onclick=@( () => Game.SelectCard( RogueChessTeam.Blue, index ) )>
							<div class="card-shine"></div>
							<div class="collapsed-row">
								<div class="card-thumb">
									<div class="card-image thumbnail @cardImageClass"></div>
								</div>
								<div class="card-summary">
									<div class="card-name">@CardData.All[card].Name</div>
								</div>
								<div class="card-cost">
									<div class="cost-number">@CardData.All[card].Cost</div>
								</div>
							</div>
							@if ( expanded )
							{
								<div class="expanded-section">
									<div class="card-image-wrap">
										<div class="card-image full @cardImageClass"></div>
									</div>
									<div class="card-rules-box">
										<div class="card-text">@CardData.All[card].RulesText</div>
										<div class="card-flavor">@visual.FlavorText</div>
									</div>
									<div class="card-rarity-row">
										<div class="rarity-text">@visual.RarityText</div>
										<div class="rarity-dots"><span></span><span></span><span></span></div>
									</div>
								</div>
							}
						</div>
					}
				</div>

				<div class="center">
					<div class="board-balance-spacer"></div>
					<div class="board">
						@for ( var y = 0; y < RogueChessGameComponent.BoardSize; y++ )
						{
							<div class="board-row">
								@for ( var x = 0; x < RogueChessGameComponent.BoardSize; x++ )
								{
									var tileX = x;
									var tileY = y;
									var unit = Game.GetUnitAt( tileX, tileY );
									var tileCue = Game.GetTileCueText( tileX, tileY );
									var hitSplatClass = Game.GetHitEffectClass( tileX, tileY, "hit-splat-effect" );
									var hitSparkClass = Game.GetHitEffectClass( tileX, tileY, "hit-spark-effect" );
									var dyingUnitClass = Game.GetDyingUnitTokenClass( tileX, tileY );
									var deathSplatClass = Game.GetDeathSplatClass( tileX, tileY, "death-splat-effect" );
									var deathSwirlClass = Game.GetDeathSplatClass( tileX, tileY, "death-swirl-effect" );
									<div class="@Game.GetTileClass( tileX, tileY )" onclick=@( () => Game.ClickTile( tileX, tileY ) )>
										@if ( Game.IsResourceTile( tileX, tileY ) )
										{
											<div class="resource-mark">Scrap Tile</div>
										}

										@if ( unit is not null )
										{
											<div class="piece-token image-token @GetPieceImageClass( unit )">
												<div class="piece-art">
												</div>
												<div class="piece-hp">
													<span>@unit.Health/@unit.MaxHealth</span>
													@if ( unit.Shield > 0 )
													{
														<span> +@unit.Shield SH</span>
													}
												</div>
											</div>
											@if ( !unit.CanActThisTurn )
											{
												<div class="unit-wait">@(unit.IsDisabledThisTurn ? "DISABLED" : "NEXT TURN")</div>
											}
										}
										@if ( !string.IsNullOrEmpty( dyingUnitClass ) )
										{
											<div class="@dyingUnitClass">
												<div class="piece-art">
													<div class="piece-label">KO</div>
												</div>
												<div class="@deathSplatClass"></div>
												<div class="@deathSwirlClass"></div>
											</div>
										}
										@if ( !string.IsNullOrEmpty( hitSplatClass ) )
										{
											<div class="@hitSplatClass"></div>
											<div class="@hitSparkClass"></div>
										}
										@if ( !string.IsNullOrEmpty( tileCue ) )
										{
											<div class="tile-cue">@tileCue</div>
										}
									</div>
								}
							</div>
						}
					</div>

					<div class="status-row">
						<div class="status">
							@if ( Game.Winner is not null )
							{
								<span>@Game.StatusMessage</span>
							}
							else
							{
								<span>@Game.StatusMessage</span>
							}
						</div>
						<div class="actions">
							@if ( Game.Winner is not null )
							{
								<div class="action-button play-again" onclick=@Game.RestartMatch>Play Again</div>
							}
							else
							{
								<div class="action-button" onclick=@Game.HandleTurnButton>@TurnButtonText</div>
								<div class="action-button" onclick=@Game.RestartMatch>Restart Match</div>
								<div class="mode-button-row">
									<div class="@GetModeButtonClass( RogueChessMode.PlayerVsComputer )" onclick=@( () => Game.SetMode( RogueChessMode.PlayerVsComputer ) )>PVE</div>
									<div class="@GetModeButtonClass( RogueChessMode.ComputerVsComputer )" onclick=@( () => Game.SetMode( RogueChessMode.ComputerVsComputer ) )>PVC</div>
								</div>
								@if ( Game.SelectedCardIndex >= 0 )
								{
									<div class="action-button cancel" onclick=@Game.CancelSelectedCard>Cancel Card</div>
								}
								else
								{
									<div class="action-button" onclick=@ShowHowToPlay>How To Play</div>
								}
							}
						</div>
					</div>
				</div>

				<div class="hand-panel red-hand @(Game.CurrentTeam == RogueChessTeam.Red ? "active-hand" : "inactive-hand")">
					<div class="hand-info">
						<div class="hand-title">Red Player</div>
						<div class="side-scrap">Scrap: @Game.RedScrap</div>
						<div class="hand-help">Draws 1 card at start of Red turn.</div>
					</div>
					@for ( var i = 0; i < Game.RedHand.Count; i++ )
					{
						var card = Game.RedHand[i];
						var index = i;
						var visual = CardData.Visuals[card];
						var cardImageClass = GetCardImageClass( card, RogueChessTeam.Red );
						var expanded = Game.CurrentTeam == RogueChessTeam.Red && Game.SelectedCardIndex == index;
						<div class="@(Game.GetCardClass( RogueChessTeam.Red, index ) + " " + visual.ArtClass)" onclick=@( () => Game.SelectCard( RogueChessTeam.Red, index ) )>
							<div class="card-shine"></div>
							<div class="collapsed-row">
								<div class="card-thumb">
									<div class="card-image thumbnail @cardImageClass"></div>
								</div>
								<div class="card-summary">
									<div class="card-name">@CardData.All[card].Name</div>
								</div>
								<div class="card-cost">
									<div class="cost-number">@CardData.All[card].Cost</div>
								</div>
							</div>
							@if ( expanded )
							{
								<div class="expanded-section">
									<div class="card-image-wrap">
										<div class="card-image full @cardImageClass"></div>
									</div>
									<div class="card-rules-box">
										<div class="card-text">@CardData.All[card].RulesText</div>
										<div class="card-flavor">@visual.FlavorText</div>
									</div>
									<div class="card-rarity-row">
										<div class="rarity-text">@visual.RarityText</div>
										<div class="rarity-dots"><span></span><span></span><span></span></div>
									</div>
								</div>
							}
						</div>
					}
				</div>
			</div>
		}
	}
	</div>
</root>

@code
{
	[Parameter] public RogueChessGameComponent Game { get; set; }
	bool ShowArmyBuilder { get; set; } = true;
	bool ShowIntro { get; set; }
	UnitType BuilderDetailsUnit { get; set; } = UnitType.Commander;
	string BuilderNotice { get; set; } = "";
	int IntroPage { get; set; }
	const int IntroPageCount = 7;
	string IntroBackClass => IntroPage == 0 ? "nav-button disabled" : "nav-button";
	string StartMatchButtonClass => Game?.IsBlueArmyComplete == true ? "builder-primary-button" : "builder-primary-button disabled";
	string ModeText => Game?.Mode switch
	{
		RogueChessMode.PlayerVsComputer => "Player vs Computer: Blue human, Red CPU",
		RogueChessMode.PlayerVsPlayer => "Player vs Player: both human",
		RogueChessMode.ComputerVsComputer => $"Computer vs Computer — Blue: {Game.DifficultyFor( RogueChessTeam.Blue )}, Red: {Game.DifficultyFor( RogueChessTeam.Red )}",
		_ => ""
	};

	string TurnButtonText => Game?.Mode == RogueChessMode.ComputerVsComputer ? "Stop Game" : "End Turn [Space]";
	string WinnerReasonText => Game?.WinReason switch
	{
		"elimination" => "Enemy army wiped out",
		"knockout" => "Enemy Commander down",
		_ => ""
	};

	void TryStartMatch()
	{
		if ( Game is null || !Game.IsBlueArmyComplete )
		{
			BuilderNotice = "Fill all 7 open army slots before starting.";
			StateHasChanged();
			return;
		}

		Game.StartMatchFromArmyBuilder();
		if ( Game.MatchStarted )
		{
			ShowArmyBuilder = false;
			ShowIntro = false;
			BuilderNotice = "";
		}

		StateHasChanged();
	}

	void SelectBuilderUnit( UnitType unitType )
	{
		BuilderDetailsUnit = unitType;
		Game?.SelectArmyBuilderUnit( unitType );
		StateHasChanged();
	}

	void SetBuilderDetailsUnit( UnitType unitType )
	{
		BuilderDetailsUnit = unitType;
		StateHasChanged();
	}

	void ClickArmyBuilderSlot( int armySlot )
	{
		if ( Game is null )
			return;

		var slotType = Game.BlueArmyChoices[armySlot];
		if ( armySlot == RogueChessGameComponent.CommanderArmySlotIndex )
		{
			SetBuilderDetailsUnit( UnitType.Commander );
			return;
		}

		if ( slotType.HasValue && slotType.Value == Game.SelectedArmyBuilderUnit )
			Game.ClearBlueArmySlot( armySlot );
		else
			Game.SetBlueArmySlot( armySlot );

		StateHasChanged();
	}

	void ShowSettingsStatus()
	{
		BuilderNotice = "Settings are not implemented yet.";
		StateHasChanged();
	}

	string GetBuilderSlotClass( UnitType unitType, bool filled, bool locked = false )
	{
		var classes = new List<string> { "builder-slot", filled ? "filled" : "empty", unitType.ToString().ToLower() };
		if ( locked )
			classes.Add( "locked" );

		return string.Join( " ", classes );
	}

	string GetBuilderSlotActionText( int armySlot, UnitType unitType )
	{
		if ( armySlot == RogueChessGameComponent.CommanderArmySlotIndex )
			return "Locked";

		return Game?.SelectedArmyBuilderUnit == unitType ? "Click to clear" : "Click to replace";
	}

	string GetBuilderUnitCardClass( UnitType unitType )
	{
		var classes = new List<string> { "unit-pool-card", unitType.ToString().ToLower() };
		if ( Game?.SelectedArmyBuilderUnit == unitType )
			classes.Add( "selected" );

		return string.Join( " ", classes );
	}

	string GetBuilderPortraitClass( UnitType unitType )
	{
		return $"builder-portrait {unitType.ToString().ToLower()} {GetPieceImageClass( new UnitData( 0, RogueChessTeam.Blue, unitType, default ) )}";
	}

	string GetUnitShortName( UnitType unitType )
	{
		return Game?.CreatePreviewUnit( unitType ).ShortName ?? "";
	}

	public override void Tick()
	{
		base.Tick();

		// Keyboard button events route to the focused panel, so keep focus here
		// (nothing else in this UI is focusable) to make the End Turn shortcut work.
		if ( !HasFocus )
		{
			AcceptsFocus = true;
			Focus();
		}
	}

	public override void OnButtonEvent( ButtonEvent e )
	{
		if ( e.Pressed && ( e.Button == "space" || e.Button == "tab" ) && CanEndTurnByKey() )
		{
			Game.EndTurn();
			StateHasChanged();
			e.StopPropagation = true;
			return;
		}

		base.OnButtonEvent( e );
	}

	bool CanEndTurnByKey()
	{
		return Game is not null
			&& !ShowArmyBuilder
			&& !ShowIntro
			&& Game.MatchStarted
			&& !Game.IsGameOver
			&& !Game.IsCurrentAiTurn()
			&& Game.Mode != RogueChessMode.ComputerVsComputer;
	}

	string GetModeButtonClass( RogueChessMode mode )
	{
		return Game?.Mode == mode ? "mode-button active" : "mode-button";
	}

	string GetDifficultyButtonClass( AiDifficulty difficulty )
	{
		return Game?.Difficulty == difficulty ? "difficulty-button active" : "difficulty-button";
	}

	string GetPieceImageClass( UnitData unit )
	{
		if ( unit.Team == RogueChessTeam.Blue )
		{
			return unit.Type switch
			{
				UnitType.Commander => "piece-commander-blue",
				UnitType.Buddy => "piece-buddy-blue",
				UnitType.Shooter => "piece-shooter-blue",
				UnitType.Tank => "piece-tank-blue",
				UnitType.Hacker => "piece-hacker-blue",
				_ => ""
			};
		}

		return unit.Type switch
		{
			UnitType.Commander => "piece-commander-red",
			UnitType.Buddy => "piece-buddy-red",
			UnitType.Shooter => "piece-shooter-red",
			UnitType.Tank => "piece-tank-red",
			UnitType.Hacker => "piece-hacker-red",
			_ => ""
		};
	}

	string GetCardImageClass( CardType cardType, RogueChessTeam team )
	{
		if ( team == RogueChessTeam.Blue )
		{
			return cardType switch
			{
				CardType.Guard => "card-image-guard-blue",
				CardType.Push => "card-image-push-blue",
				CardType.Focus => "card-image-focus-blue",
				CardType.Sprint => "card-image-sprint-blue",
				CardType.BuildBuddy => "card-image-build-buddy-blue",
				CardType.Repair => "card-image-repair-blue",
				CardType.Reboot => "card-image-repair-blue", // placeholder art (no dedicated Reboot asset yet)
				_ => ""
			};
		}

		return cardType switch
		{
			CardType.Guard => "card-image-guard-red",
			CardType.Push => "card-image-push-red",
			CardType.Focus => "card-image-focus-red",
			CardType.Sprint => "card-image-sprint-red",
			CardType.BuildBuddy => "card-image-build-buddy-red",
			CardType.Repair => "card-image-repair-red",
			CardType.Reboot => "card-image-repair-red", // placeholder art (no dedicated Reboot asset yet)
			_ => ""
		};
	}

	void StartGame()
	{
		ShowIntro = false;
		if ( Game?.MatchStarted == true )
			ShowArmyBuilder = false;
		else
			ShowArmyBuilder = true;

		StateHasChanged();
	}

	void ShowHowToPlay()
	{
		ShowArmyBuilder = false;
		ShowIntro = true;
		IntroPage = 0;
		StateHasChanged();
	}

	void PreviousIntroPage()
	{
		if ( IntroPage > 0 )
			IntroPage--;

		StateHasChanged();
	}

	void NextIntroPage()
	{
		if ( IntroPage < IntroPageCount - 1 )
			IntroPage++;

		StateHasChanged();
	}

	protected override int BuildHash()
	{
		return HashCode.Combine( Game?.UiVersion ?? 0, ShowArmyBuilder, ShowIntro, IntroPage, BuilderDetailsUnit, BuilderNotice );
	}
}
